{
  "name": "erp-system",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.9",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@tanstack/react-form": "^1.28.0",
      "@types/react-dom": "^19.2.3",
      "@better-auth/expo": "1.6.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo -F web -F server -F native -F @erp-system/db dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @erp-system/db db:push",
    "db:studio": "turbo -F @erp-system/db db:studio",
    "db:generate": "turbo -F @erp-system/db db:generate",
    "db:migrate": "turbo -F @erp-system/db db:migrate",
    "db:start": "turbo -F @erp-system/db db:start",
    "db:watch": "turbo -F @erp-system/db db:watch",
    "db:stop": "turbo -F @erp-system/db db:stop",
    "db:down": "turbo -F @erp-system/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@erp-system/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@erp-system/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^6",
    "ultracite": "7.7.0"
  },
  "packageManager": "bun@1.2.18"
}
